:80 {
    root * /usr/share/caddy
    file_server
    try_files {path} /index.html
    header -Server

    @assets path /assets/*
    handle @assets {
        header Cache-Control "public, max-age=31536000, immutable"
    }

    @static path *.svg *.png /robots.txt
    handle @static {
        header Cache-Control "public, max-age=86400"
    }

    handle {
        header Cache-Control "no-cache"
    }
}
